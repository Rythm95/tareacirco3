<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="555.0" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.EspectaculoDetalleController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
			<padding>
				<Insets bottom="10" left="20" right="20" top="10" />
			</padding>
			<Label styleClass="title" text="Detalle del Espectáculo" />
			<HBox HBox.hgrow="ALWAYS" />
			<Button onAction="#goBack" styleClass="btn-primary" text="Volver" />
		</HBox>
	</top>
	<center>
		<ScrollPane fitToWidth="true" stylesheets="@../styles/Styles.css">
			<content>
				<VBox spacing="15" styleClass="formulario">
					<padding>
						<Insets bottom="20" left="20" right="20" top="20" />
					</padding>
					<VBox spacing="5">
						<Label styleClass="card-titulo" text="Datos del espectáculo:" />
						<Label fx:id="lblId" />
						<Label fx:id="lblNombre" />
						<Label fx:id="lblFechas" />
					</VBox>
               <Separator prefWidth="200.0" />
					<VBox spacing="5">
						<Label styleClass="card-titulo" text="Coordinador:" />
						<Label fx:id="lblCoordNombre" />
						<Label fx:id="lblCoordEmail" />
						<Label fx:id="lblCoordSenior" />
                  <VBox.margin>
                     <Insets />
                  </VBox.margin>
					</VBox>
               <Separator prefWidth="200.0" />
					<VBox spacing="10">
						<Label styleClass="card-titulo" text="Números del espectáculo:" />
						<VBox fx:id="numerosContainer" spacing="10" />
					</VBox>
				</VBox>
			</content>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
		</ScrollPane>
	</center>
</BorderPane>
