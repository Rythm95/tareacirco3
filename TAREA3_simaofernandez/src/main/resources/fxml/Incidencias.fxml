<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/25"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.simao.tarea3AD2024base.controller.IncidenciaController">
	<children>
		<HBox alignment="CENTER_LEFT" prefHeight="28.0" prefWidth="516.0">
			<children>
				<HBox maxWidth="230.0" HBox.hgrow="ALWAYS">
					<children>
						<Label styleClass="subtitulo" text="Incidencias:" />
					</children>
				</HBox>
				<Button fx:id="btnForms" mnemonicParsing="false"
					onAction="#switchForms" prefHeight="26.0" prefWidth="150.0"
					styleClass="btn-secondary" text="Registrar incidencias" />
			</children>
		</HBox>
		<VBox fx:id="formRegistro" managed="false" spacing="10"
			styleClass="formulario" visible="false">
			<children>
				<Label styleClass="subtitulo"
					text="Registrar nueva incidencia" />
				<GridPane hgap="10" vgap="10">
					<columnConstraints>
						<ColumnConstraints percentWidth="25" />
						<ColumnConstraints percentWidth="75" />
					</columnConstraints>
					<rowConstraints>
						<RowConstraints />
						<RowConstraints />
						<RowConstraints />
						<RowConstraints />
					</rowConstraints>
					<children>
						<Label text="Tipo:" GridPane.columnIndex="0"
							GridPane.rowIndex="0" />
						<ComboBox fx:id="cbTipo" prefWidth="250"
							GridPane.columnIndex="1" GridPane.rowIndex="0" />
						<Label text="Id espectáculo:" GridPane.columnIndex="0"
							GridPane.rowIndex="1" />
						<ComboBox fx:id="cbIdEspectaculo" prefWidth="150.0"
							GridPane.columnIndex="1" GridPane.rowIndex="1" />
						<Label text="Id número:" GridPane.columnIndex="0"
							GridPane.rowIndex="2" />
						<ComboBox fx:id="cbIdNumero" prefWidth="150"
							GridPane.columnIndex="1" GridPane.rowIndex="2" />
						<Label text="Descripción:" GridPane.columnIndex="0"
							GridPane.rowIndex="3" />
						<TextArea fx:id="txtDescripcion" prefRowCount="5"
							promptText="Describe la incidencia..." wrapText="true"
							GridPane.columnIndex="1" GridPane.rowIndex="3" />
					</children>
				</GridPane>
				<Label fx:id="lblErrorIncidencia" managed="false"
					styleClass="error-label" text="Error" visible="false"
					wrapText="true" />
				<HBox spacing="10">
					<children>
						<Button onAction="#registrarIncidencia"
							text="Registrar incidencia" />
						<Label fx:id="lblRegistro" styleClass="success-label" />
					</children>
				</HBox>
			</children>
		</VBox>
		<VBox fx:id="formConsulta" spacing="10" styleClass="formulario">
			<children>
				<Label styleClass="subtitulo" text="Consultar incidencias" />
				<GridPane hgap="10" vgap="10">
					<columnConstraints>
						<ColumnConstraints percentWidth="20" />
						<ColumnConstraints percentWidth="30" />
						<ColumnConstraints percentWidth="20" />
						<ColumnConstraints percentWidth="30" />
					</columnConstraints>
					<rowConstraints>
						<RowConstraints />
						<RowConstraints />
						<RowConstraints />
					</rowConstraints>
					<children>
						<Label text="Tipo:" GridPane.columnIndex="0"
							GridPane.rowIndex="0" />
						<ComboBox fx:id="cbFiltroTipo" GridPane.columnIndex="1"
							GridPane.rowIndex="0" />
						<Label text="Estado:" GridPane.columnIndex="2"
							GridPane.rowIndex="0" />
						<ComboBox fx:id="cbFiltroEstado" GridPane.columnIndex="3"
							GridPane.rowIndex="0" />
						<Label text="Fecha inicio:" GridPane.columnIndex="0"
							GridPane.rowIndex="1" />
						<DatePicker fx:id="dpFechaInicio"
							GridPane.columnIndex="1" GridPane.rowIndex="1" />
						<Label text="Fecha fin:" GridPane.columnIndex="2"
							GridPane.rowIndex="1" />
						<DatePicker fx:id="dpFechaFin" GridPane.columnIndex="3"
							GridPane.rowIndex="1" />
						<Label text="Id espectáculo:" GridPane.columnIndex="0"
							GridPane.rowIndex="2" />
						<ComboBox fx:id="cbFiltroEspectaculo"
							GridPane.columnIndex="1" GridPane.rowIndex="2" />
						<Label text="Id número:" GridPane.columnIndex="2"
							GridPane.rowIndex="2" />
						<ComboBox fx:id="cbFiltroNumero" GridPane.columnIndex="3"
							GridPane.rowIndex="2" />
					</children>
				</GridPane>
				<HBox spacing="10">
					<children>
						<Button onAction="#buscarIncidencias" text="Buscar" />
						<Button onAction="#limpiarFiltros" text="Limpiar filtros" />
					</children>
				</HBox>
			</children>
		</VBox>
		<VBox spacing="10">
			<children>
				<TableView fx:id="tablaIncidencias" VBox.vgrow="ALWAYS">
					<columns>
						<TableColumn fx:id="colId" prefWidth="60" text="ID" />
						<TableColumn fx:id="colFecha" prefWidth="180"
							text="Fecha" />
						<TableColumn fx:id="colTipo" prefWidth="130"
							text="Tipo" />
						<TableColumn fx:id="colDescripcion" prefWidth="350"
							text="Descripción" />
						<TableColumn fx:id="colResuelta" prefWidth="90"
							text="Resuelta" />
						<TableColumn fx:id="colPersona" prefWidth="90"
							text="Reporta" />
						<TableColumn fx:id="colEspectaculo" prefWidth="100"
							text="Espectáculo" />
						<TableColumn fx:id="colNumero" prefWidth="100"
							text="Número" />
					</columns>
				</TableView>
			</children>
		</VBox>
		<VBox fx:id="formResolve" spacing="10" styleClass="formulario">
			<children>
				<Label styleClass="subtitulo"
					text="Resolver incidencia seleccionada" />
				<TextArea fx:id="txtResolucion" prefRowCount="4"
					promptText="Acciones realizadas para resolver la incidencia..."
					wrapText="true" />
				<HBox spacing="10">
					<children>
						<Button onAction="#resolverIncidencia"
							text="Marcar como resuelta" />
						<Label fx:id="lblResolucion" styleClass="success-label" />
					</children>
				</HBox>
			</children>
		</VBox>
	</children>
	<padding>
		<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
	</padding>
</VBox>
