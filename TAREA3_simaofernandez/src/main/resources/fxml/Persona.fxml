<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="555.0" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.PersonaController">
	<top>
		<VBox prefHeight="37.0" prefWidth="556.0" BorderPane.alignment="CENTER">
			<children>
				<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
					<padding>
						<Insets bottom="10" left="20" right="20" top="10" />
					</padding>
					<Label styleClass="title" text="Número" />
					<HBox HBox.hgrow="ALWAYS" />
					<Button onAction="#goBack" styleClass="btn-primary" text="Volver" />
				</HBox>
            <Separator prefWidth="200.0" />
			</children>
		</VBox>
	</top>
   <center>
      <VBox spacing="15" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
         </padding>
         <children>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefWidth="526.0" >
      <content>
      	<VBox spacing="10" styleClass="formulario">
      		<TextField fx:id="txtNombre" promptText="Nombre Real" />
      		<Label fx:id="lblErrorNombre" managed="false" styleClass="error-label" text="Error" visible="false" wrapText="true" />
            <TextField fx:id="txtEmail" promptText="Email" />
            <Label fx:id="lblErrorEmail" managed="false" styleClass="error-label" text="Error" visible="false" wrapText="true" />
            <ComboBox fx:id="cbNacionalidad" prefWidth="150.0" promptText="Nacionalidad" />
            <HBox prefHeight="0.0" prefWidth="526.0" spacing="30.0">
               <children>
                  <RadioButton fx:id="rbCoord" mnemonicParsing="false" selected="true" text="Coordinador/a" />
                  <RadioButton fx:id="rbArt" mnemonicParsing="false" prefWidth="63.0" text="Artista" />
               </children>
            </HBox>
            <VBox fx:id="coordContainer" prefHeight="0.0" prefWidth="526.0" spacing="10.0">
               <children>
                  <CheckBox fx:id="checkSenior" mnemonicParsing="false" text="Coordinador/a Senior" />
                  <DatePicker fx:id="dpSenior" managed="false" promptText="Desde..." visible="false" />
               </children>
            </VBox>
            <TextField fx:id="txtUser" promptText="Nombre de usuario" />
            <Label fx:id="lblErrorUser" managed="false" styleClass="error-label" text="Error" visible="false" wrapText="true" />
            <TextField fx:id="txtPass" promptText="Contraseña" />
            <Label fx:id="lblErrorPass" managed="false" styleClass="error-label" text="Error" visible="false" wrapText="true" />
      		<Label fx:id="lblError" styleClass="error-label" text="Error" visible="false" wrapText="true" />
      		</VBox>
      </content>
   </ScrollPane>
            <Label fx:id="lblError" styleClass="error-label" text="Error" visible="false" />
            <HBox spacing="10">
               <children>
                  <Button onAction="#save" text="Actualizar Número" />
                  <Button onAction="#reiniciarForm" text="Reiniciar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
