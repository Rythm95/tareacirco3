<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="345.0" prefWidth="556.0" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.InvitadoController">
    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label styleClass="subtitulo" text="Espectáculos Programados:">
            <VBox.margin>
               <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </VBox.margin></Label>
         <Separator prefWidth="200.0" />
            <VBox fx:id="espectaculosContainer" spacing="10" />
        </VBox>
    </center>
   <top>
      <VBox prefHeight="37.0" prefWidth="556.0" BorderPane.alignment="CENTER">
         <children>
            <MenuBar>
              <menus>
                <Menu mnemonicParsing="false" text="File">
                  <items>
                    <MenuItem mnemonicParsing="false" text="Close" />
                  </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                  <items>
                    <MenuItem mnemonicParsing="false" text="Delete" />
                  </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                  <items>
                    <MenuItem mnemonicParsing="false" text="About" />
                  </items>
                </Menu>
              </menus>
            </MenuBar>
              <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
                  <padding>
                      <Insets bottom="10" left="20" right="20" top="10" />
                  </padding>
                  <Label styleClass="titulo" text="Invitado" />
                  <HBox HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnInicioSesion" onAction="#login" styleClass="btn-login" text="Iniciar Sesión" />
              </HBox>
         </children>
      </VBox>
   </top>
</BorderPane>
