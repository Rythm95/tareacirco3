<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="555.0" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.NumeroController">
	<top>
		<VBox prefHeight="37.0" prefWidth="556.0" BorderPane.alignment="CENTER">
			<children>
				<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
					<padding>
						<Insets bottom="10" left="20" right="20" top="10" />
					</padding>
					<Label styleClass="title" text="Número" />
					<HBox HBox.hgrow="ALWAYS" />
					<Button onAction="#goBack" styleClass="btn-primary" text="Volver" />
				</HBox>
            <Separator prefWidth="200.0" />
			</children>
		</VBox>
	</top>
   <center>
      <VBox spacing="15" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
         </padding>
         <children>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="526.0">
               <content>
                  <VBox styleClass="formulario" spacing="10">
                     <children>
                        <TextField fx:id="txtNombre" promptText="Nombre del Número" />
                        <Label fx:id="lblErrorNombre" managed="false" styleClass="error-label" text="Error" visible="false" />
                        <VBox>
                           <children>
                              <Label text="Duración del Número:" />
                              <HBox alignment="CENTER_LEFT" spacing="10">
                                 <children>
                                    <Spinner fx:id="spMinutos" editable="true" prefWidth="70" />
                                    <ComboBox fx:id="cbDecimal" prefWidth="70" promptText=".0" />
                                    <Label text="Minutos" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox spacing="5">
                           <children>
                              <Label text="Artistas participantes:" />
                              <VBox fx:id="containerArtistas" />
                           </children>
                        </VBox>
                        <Label fx:id="lblError" styleClass="error-label" text="Error" visible="false" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <Label fx:id="lblError" styleClass="error-label" text="Error" visible="false" />
            <HBox spacing="10">
               <children>
                  <Button fx:id="save" onAction="#save" text="Actualizar Número" />
                  <Button onAction="#reiniciarForm" text="Reiniciar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
