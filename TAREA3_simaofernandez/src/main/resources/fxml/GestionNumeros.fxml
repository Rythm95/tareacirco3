<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.GestionNumerosController">
	<padding>
		<Insets bottom="20" left="20" right="20" top="20" />
	</padding>
	<HBox alignment="CENTER_LEFT" prefHeight="28.0" prefWidth="516.0">
		<children>
			<HBox maxWidth="230.0" HBox.hgrow="ALWAYS">
				<children>
					<Label styleClass="subtitulo" text="Números Registrados:" />
				</children>
			</HBox>
			<Button fx:id="btnForm" mnemonicParsing="false" onAction="#showForm" prefHeight="25.0" prefWidth="125.0" styleClass="btn-secondary" text="Nuevo Número" />
		</children>
	</HBox>
	<ScrollPane fx:id="formularioBox" fitToWidth="true" hbarPolicy="NEVER" managed="false" prefWidth="526.0" visible="false">
		<content>
			<VBox spacing="10">
				<TextField fx:id="txtNombre" promptText="Nombre del Número" />
				<Label fx:id="lblErrorNombre" styleClass="error-label" text="Error" visible="false" managed="false" />
				<VBox>
					<Label text="Duración del Número:" />
					<HBox alignment="CENTER_LEFT" spacing="10">
						<Spinner fx:id="spMinutos" editable="true" prefWidth="70" />
						<ComboBox fx:id="cbDecimal" prefWidth="70" promptText=".0" />
						<Label text="Minutos" />
					</HBox>
				</VBox>
				<VBox spacing="5">
					<Label text="Artistas participantes:" />
               <ScrollPane fx:id="artistasBox" hbarPolicy="NEVER" fitToWidth="true" fitToHeight="true">
                 <content>
                     <VBox fx:id="containerArtistas" />
                 </content>
               </ScrollPane>
				</VBox>
				<Label fx:id="lblError" styleClass="error-label" text="Error" visible="false" />
				<HBox spacing="10">
					<Button fx:id="save" onAction="#save" text="Guardar" />
					<Button onAction="#limpiarForm" text="Limpiar" />
				</HBox>
			</VBox>
		</content>
	</ScrollPane>
	<Separator prefWidth="200.0" />
	<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefWidth="526.0">
		<content>
			<VBox fx:id="container" spacing="10">
				<padding>
					<Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
				</padding>
			</VBox>
		</content>
	</ScrollPane>
</VBox>
